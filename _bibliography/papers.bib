  bibtex_show = {true},
  title       = {LENS: Leveraging Explainable Skills for Listwise Evaluation in Kuaishou Search},
  author      = {Huang*, Zhongxin and others},
  abstract    = {A skill-based whole-page search quality evaluation framework enabling automated GSB evaluation and bad-case attribution. We propose a two-stage SFT + DAPO-based training scheme whose offline classification accuracy and attribution recall clearly surpass mainstream LLM baselines. Online human spot-check consistency reached 84.2\%, with evaluation efficiency 40.6x over manual annotation on L20 machines.},
